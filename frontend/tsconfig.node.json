{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./.tsbuild/node",
    "allowSyntheticDefaultImports": true
  },
  "include": ["vite.config.js"]
}
